---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ScrollRevealBanner from "../components/ScrollRevealBanner.astro";
import ProductGrid from "../components/ProductGrid";
import About from "../components/About.astro";
import Footer from "../components/Footer.astro";
import FeaturesBanner from "../components/FeaturesBanner.astro";
import LookOfTheWeek from "../components/LookOfTheWeek.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import BlogHome from "../components/BlogHome.astro";
import { getHomeSEO, getProductsByCategory } from "../lib/woocommerce";

export const prerender = false;

// Helper: ejecuta una promesa con timeout (ms). Si excede, devuelve el fallback.
function withTimeout<T>(promise: Promise<T>, ms: number, fallback: T): Promise<T> {
  return Promise.race([
    promise,
    new Promise<T>((resolve) => setTimeout(() => resolve(fallback), ms)),
  ]);
}

// Todas las llamadas al API en paralelo con timeout global de 3s para no bloquear el SSR.
const [homeSeo, initialProducts] = await Promise.all([
  withTimeout(getHomeSEO(), 3000, null),
  withTimeout(getProductsByCategory("63", 24, 1, "popularity", "desc"), 3000, []),
]);
---

<Layout title={homeSeo?.title} seoData={homeSeo}>
	<Header />

	<main>
		<Hero />

		<div class="content-wrapper">
			<FeaturesBanner />
			<CategoryGrid />
			<ProductGrid client:load initialProducts={initialProducts} />
			<ScrollRevealBanner
				imageUrl="/images/banner-look-completo.webp"
				title="Estilo que se construye con intención"
				description="Cada prenda está pensada para integrarse a tu forma de vestir y a tu ritmo. Descubre ropa que suma, combina y se adapta a tu día. chaquetas, camisas y suéteres."
				pretitle="Winston & Harry"
			/>
			<LookOfTheWeek />
			<About />
		</div>
	</main>

	<Footer />
</Layout>

<style is:global>
	/* Smoothie scroll */
	html {
		scroll-behavior: smooth;
	}

	main {
		/* Eliminamos overflow-x para permitir que position: sticky funcione en los componentes hijos */
	}

	.content-wrapper {
		position: relative;
		z-index: 10;
		background-color: var(--color-white);
	}
</style>

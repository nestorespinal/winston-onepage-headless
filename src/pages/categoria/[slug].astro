---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProductCard from "../../components/ProductCard";
import {
    getCategoryBySlug,
    getProductsByCategory,
    getChildCategories,
    getCategoryTree,
    getAttributeTerms,
    getCategoryById,
    PUBLIC_WP_URL,
} from "../../lib/woocommerce";
import FilteredProductList from "../../components/FilteredProductList";

export const prerender = false;
export const isr = {
    expiration: 86400, // 24 horas (revalidación bajo demanda)
};

const { slug } = Astro.params;
const sortParam = Astro.url.searchParams.get("sort") || "destacado";
const colorParam = Astro.url.searchParams.get("color") || null;
const tallaParam = Astro.url.searchParams.get("talla") || null;

// Mapeo del param de URL a los parámetros de la API WooCommerce
const SORT_OPTIONS = [
    {
        key: "recientes",
        label: "Más recientes",
        orderBy: "modified",
        order: "desc",
        onSale: false,
    },
    {
        key: "destacado",
        label: "Destacado",
        orderBy: "popularity",
        order: "desc",
        onSale: false,
    },
    {
        key: "precio_asc",
        label: "Menor a mayor precio",
        orderBy: "price",
        order: "asc",
        onSale: false,
    },
    {
        key: "precio_desc",
        label: "Mayor a menor precio",
        orderBy: "price",
        order: "desc",
        onSale: false,
    },
    {
        key: "descuentos",
        label: "Descuentos",
        orderBy: "popularity",
        order: "desc",
        onSale: true,
    },
];

const activeSort =
    SORT_OPTIONS.find((o) => o.key === sortParam) || SORT_OPTIONS[0];

let category: any = null;
let wpCategory: any = null;
let products: any[] = [];
let error: string | null = null;
let colorTerms: any[] = [];
let tallaTerms: any[] = [];

let subcategories: any[] = [];
let navigationTree: any[] = [];

try {
    // 1. Buscamos la categoría en WooCommerce (para productos e ID)
    category = await getCategoryBySlug(slug as string);
    
    if (category) {
        // 2. Buscamos la categoría en WP API pública (para obtener ACF/Banners sin problemas de Auth)
        try {
            const wpRes = await fetch(`${PUBLIC_WP_URL}/wp-json/wp/v2/product_cat?slug=${slug}`);
            if (wpRes.ok) {
                const wpData = await wpRes.json();
                if (Array.isArray(wpData) && wpData.length > 0) {
                    wpCategory = wpData[0];
                }
            }
        } catch (e) {
            console.warn("Error fetching public WP category:", e);
        }

        // 3. Cargamos los productos iniciales
        products = await getProductsByCategory(
            category.id,
            16,
            1,
            activeSort.orderBy,
            activeSort.order,
            activeSort.onSale
        );

        // 4. Cargamos subcategorías REALES para el panel de filtros lateral
        let currentSubcats = await getChildCategories(category.id);
        
        // Si no tiene hijos, mostramos sus hermanos (hijos del padre) + el padre para volver
        if (currentSubcats.length === 0 && category.parent !== 0) {
            const siblings = await getChildCategories(category.parent);
            const parentCat = await getCategoryById(category.parent);
            
            subcategories = [
                ...(parentCat ? [{ 
                    id: parentCat.id, 
                    name: `TODO ${parentCat.name.toUpperCase()}`, 
                    slug: parentCat.slug 
                }] : []),
                ...siblings
            ];
        } else {
            subcategories = currentSubcats;
        }

        // 5. Cargamos el árbol completo de navegación para el dropdown superior
        navigationTree = await getCategoryTree();

        if (tallaParam) {
            products = products.filter((p) =>
                p.attributes?.some(
                    (a: any) => a.name.toLowerCase() === "talla" && a.options.includes(tallaParam),
                ),
            );
        }
    } else {
        error = "Categoría no encontrada";
    }
} catch (e) {
    console.error("Error en categoria/[slug].astro:", e);
    error = "Hubo un problema al cargar los productos.";
}

if (!category && !error) {
    return Astro.redirect("/404");
}

const bannerImage = category?.image?.src || null;
const metaData = category?.meta_data || [];
const acfData = wpCategory?.acf || {};

async function getBannerUrl(keys: string[]) {
    // 1. Prioridad: Buscar en ACF (traído de la API pública)
    for (const key of keys) {
        const val = acfData[key];
        if (!val) continue;

        if (typeof val === 'string' && val.startsWith('http')) return val;
        if (typeof val === 'object' && val.url) return val.url;
        if (!isNaN(Number(val)) && Number(val) > 0) {
            try {
                const res = await fetch(`${PUBLIC_WP_URL}/wp-json/wp/v2/media/${val}`);
                if (res.ok) {
                    const data = await res.json();
                    return data.source_url;
                }
            } catch (e) {}
        }
    }

    // 2. Fallback: Buscar en meta_data de WooCommerce
    for (const key of keys) {
        const meta = metaData.find((m: any) => m.key === key);
        if (!meta || !meta.value) continue;
        
        const val = meta.value;
        if (typeof val === 'string' && val.startsWith('http')) return val;
        if (typeof val === 'object' && val.url) return val.url;
        if (!isNaN(Number(val)) && Number(val) > 0) {
            try {
                const res = await fetch(`${PUBLIC_WP_URL}/wp-json/wp/v2/media/${val}`);
                if (res.ok) {
                    const data = await res.json();
                    return data.source_url;
                }
            } catch (e) {}
        }
    }
    return null;
}

// Desktop: Prioridad al campo de banner, luego a la imagen principal de WC
const desktopBanner = (await getBannerUrl(['banner_categoria_desktop', 'banner_desktop', 'banner_categoria'])) || bannerImage;

// Móvil: Prioridad al campo de móvil, si no existe usa la de desktop
const mobileBanner = (await getBannerUrl(['imagen_categoria_movil', 'banner_mobile', 'banner_movil'])) || desktopBanner;

const categoryTitle = category?.name || "Categoría";
const categoryDesc = category?.description?.replace(/<[^>]+>/g, "") || "";

// Header de depuración para verificar el tiempo de generación en Vercel
Astro.response.headers.set('X-Generated-At', new Date().toISOString());
Astro.response.headers.set('Cache-Control', 'public, s-maxage=86400, stale-while-revalidate=43200');
const seoData = {     title: `${categoryTitle} | Winston & Harry`,     description: categoryDesc || `Descubre nuestra colección de ${categoryTitle} en Winston & Harry.`,     opengraph_title: `${categoryTitle} | Winston & Harry`,     opengraph_description: categoryDesc || `Descubre nuestra colección de ${categoryTitle} en Winston & Harry.`,     opengraph_image: desktopBanner || null,     opengraph_type: "website" };
---

<Layout 
    title={`${categoryTitle} | Winston & Harry`}
    seoData={seoData}
>
    <Header />

    <!-- Breadcrumbs -->
    <div class="breadcrumbs-container">
        <div class="breadcrumbs">
            <a href="/">Inicio</a>
            <span class="separator">/</span>
            <span class="current">Colección {categoryTitle}</span>
        </div>
    </div>

    <main class="category-page">
        <section
            class="category-banner"
            style={`--desktop-banner: url('${desktopBanner}'); --mobile-banner: url('${mobileBanner}');`}
        >
            <div class="banner-overlay"></div>
            <div class="banner-content">
                <h1 style="color:#fff">{categoryTitle}</h1>
                {categoryDesc && <p set:html={categoryDesc} />}
            </div>
        </section>

        {error && (
            <div class="error-container">
                <p class="error-msg">{error}</p>
                <a href="/" class="btn-retry">Volver al inicio</a>
            </div>
        )}

        {!error && (
            <!-- Componente React de Filtros y Productos -->
            <FilteredProductList
                client:load
                initialProducts={products}
                category={category}
                subcategories={subcategories}
                colorTerms={colorTerms}
                tallaTerms={tallaTerms}
                initialSort={activeSort}
                navigationTree={navigationTree}
            />
        )}
    </main>

    <Footer />
</Layout>

<style is:global>
    .category-page {
        min-height: 80vh;
        background-color: #fff;
    }

    .error-container {
        text-align: center;
        padding: 5rem 2rem;
    }

    .error-msg {
        color: #721c24;
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
        padding: 1rem 2rem;
        border-radius: 4px;
        display: inline-block;
        margin-bottom: 2rem;
        font-family: var(--font-paragraphs);
    }

    .btn-retry {
        display: block;
        width: max-content;
        margin: 0 auto;
        padding: 0.8rem 2rem;
        background: var(--color-green);
        color: #fff;
        text-decoration: none;
        font-family: var(--font-titles);
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    /* Breadcrumbs */
    .breadcrumbs-container {
        max-width: var(--container-max-width);
        margin: 0 auto;
        padding: 2rem 2rem 1.5rem; /* Ajustado para el header fixed */
    }

    .breadcrumbs {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-family: var(--font-paragraphs);
        font-size: 0.75rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .breadcrumbs a {
        color: #888;
        text-decoration: none;
        transition: color 0.2s;
    }

    .breadcrumbs a:hover {
        color: var(--color-green);
    }

    .breadcrumbs .current {
        color: #333;
        font-weight: 600;
    }

    .category-banner {
        position: relative;
        height: 800px;
        background-color: var(--color-green);
        background-image: var(--desktop-banner);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    @media (max-width: 768px) {
        .category-banner {
            background-image: var(--mobile-banner);
            height: 400px;
        }
    }

    .banner-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.25);
        z-index: 1;
    }

    .banner-content {
        position: relative;
        z-index: 2;
        padding-left: 8%;
        color: #fff;
        max-width: 80%;
    }

    .banner-content h1 {
        font-family: var(--font-titles);
        font-size: 1.25rem;
        margin-bottom: 1rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        max-width: 600px;
        color: #fff !important;
    }

    .banner-content p {
        font-family: var(--font-paragraphs);
        font-size: 0.8rem;
        line-height: 1.6;
        max-width: 500px;
        opacity: 0.9;
        color: #fff !important;
    }

    /* Barra de filtros */
    .filter-bar-container {
        background: #fff;
        border-bottom: 1px solid #eee;
    }

    .filter-bar {
        max-width: var(--container-max-width);
        margin: 0 auto;
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .filter-left,
    .filter-right {
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    .category-dropdown {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        padding: 0.5rem 0;
    }

    .current-category {
        font-family: var(--font-paragraphs);
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 1px;
        color: #121212;
    }

    .dropdown-icon {
        transition: transform 0.3s ease;
    }

    .category-dropdown:hover .dropdown-icon {
        transform: rotate(180deg);
    }

    .dropdown-list {
        position: absolute;
        top: 100%;
        left: 0;
        background: #fff;
        list-style: none;
        padding: 0.5rem 0 1rem;
        margin: 0;
        min-width: 200px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        border: 1px solid #e8e8e8;
        border-top: none;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition:
            opacity 0.2s ease,
            visibility 0.2s;
        z-index: 100;
    }

    .category-dropdown:hover .dropdown-list {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
    }

    .dropdown-list li a {
        display: block;
        padding: 0.5rem 1.5rem;
        color: #666;
        text-decoration: none;
        font-family: var(--font-paragraphs);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition:
            color 0.2s,
            background-color 0.2s;
    }

    .dropdown-list li a:hover {
        color: var(--color-green);
        background-color: #f9f9f9;
    }

    .sort-dropdown {
        display: flex;
        align-items: center;
        width: 195px;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border: 1px solid #e0e0e0;
        cursor: pointer;
        position: relative;
    }

    .sort-label {
        font-family: var(--font-paragraphs);
        font-size: 0.8rem;
        color: #333;
        white-space: nowrap;
    }

    .sort-list {
        position: absolute;
        top: 100%;
        margin-right: -1px !important;
        right: 0;
        background: #fff;
        list-style: none;
        padding: 0.5rem 0 1rem;
        margin: 0;
        min-width: 195px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        border: 1px solid #e8e8e8;
        border-top: none;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition:
            opacity 0.2s ease,
            visibility 0.2s;
        z-index: 100;
    }

    .sort-dropdown:hover .sort-list {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
    }

    .sort-list li a {
        display: block;
        padding: 0.6rem 1.5rem;
        color: #666;
        text-decoration: none;
        font-family: var(--font-paragraphs);
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        transition:
            color 0.2s,
            background-color 0.2s;
        white-space: nowrap;
    }

    .sort-list li a:hover,
    .sort-list li a.active {
        color: var(--color-green);
        background-color: #f9f9f9;
        font-weight: 600;
    }

    .filter-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.2rem;
        background: transparent;
        border: 1px solid #e0e0e0;
        font-family: var(--font-paragraphs);
        font-size: 0.8rem;
        color: #333;
        cursor: pointer;
        transition: all 0.2s;
    }

    .filter-btn:hover {
        border-color: #121212;
        background: #f9f9f9;
    }

    /* Active Filters Tags */
    .active-filters {
        max-width: var(--container-max-width);
        margin: 0 auto;
        padding: 0 2rem 1.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        align-items: center;
    }

    .filter-tag {
        background: #f4f4f4;
        padding: 0.4rem 0.8rem;
        font-family: var(--font-paragraphs);
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border-radius: 4px;
        color: #333;
    }

    .filter-tag a {
        color: #999;
        text-decoration: none;
        font-size: 1.1rem;
        line-height: 1;
        padding-bottom: 2px;
        transition: color 0.2s;
    }

    .filter-tag a:hover {
        color: #000;
    }

    .clear-all {
        font-family: var(--font-paragraphs);
        font-size: 0.75rem;
        color: #888;
        text-decoration: underline;
        margin-left: 0.5rem;
    }

    /* Container Grilla */
    .container-full {
        width: 100%;
        max-width: 100%;
        margin: 0;
        padding: 0;
    }

    .products-grid-container {
        padding: 0 0 4rem;
    }

    .grid-4x3 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        width: 100%;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 10rem 2rem;
        max-width: 600px;
        margin: 0 auto;
    }

    .empty-icon {
        margin-bottom: 2rem;
        opacity: 0.5;
    }

    .empty-state h2 {
        font-family: var(--font-titles);
        font-size: 1.8rem;
        margin-bottom: 1rem;
        color: #333;
    }

    .empty-state p {
        font-family: var(--font-paragraphs);
        color: #666;
        margin-bottom: 2rem;
    }

    .btn-outline {
        display: inline-block;
        padding: 1rem 2.5rem;
        border: 1px solid #121212;
        color: #121212;
        text-decoration: none;
        font-family: var(--font-titles);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.8rem;
        transition: all 0.3s;
    }

    .btn-outline:hover {
        background: #121212;
        color: #fff;
    }

    /* Drawer de Filtros */
    .filter-drawer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.4);
        z-index: 1000;
        opacity: 0;
        visibility: hidden;
        transition: all 0.4s ease;
    }

    .filter-drawer-overlay.active {
        opacity: 1;
        visibility: visible;
    }

    .filter-drawer {
        position: fixed;
        top: 0;
        right: -400px;
        width: 400px;
        height: 100%;
        background: #fff;
        z-index: 1001;
        display: flex;
        flex-direction: column;
        transition: right 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        box-shadow: -10px 0 30px rgba(0, 0, 0, 0.1);
    }

    .filter-drawer.active {
        right: 0;
    }

    @media (max-width: 480px) {
        .filter-drawer {
            width: 100%;
            right: -100%;
        }
    }

    .drawer-header {
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #eee;
    }

    .drawer-header h3 {
        font-family: var(--font-titles);
        font-size: 1.25rem;
        color: var(--color-green);
        margin: 0;
    }

    .close-drawer {
        background: none;
        border: none;
        font-size: 2rem;
        cursor: pointer;
        padding: 0;
        line-height: 1;
        color: #888;
    }

    .drawer-content {
        flex: 1;
        overflow-y: auto;
        padding: 2rem;
    }

    .filter-group {
        margin-bottom: 2.5rem;
    }

    .filter-group h4 {
        font-family: var(--font-titles);
        font-size: 0.9rem;
        margin-bottom: 1.2rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #121212;
    }

    .filter-list-v {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .filter-list-v li {
        margin-bottom: 0.6rem;
    }

    .filter-list-v li a {
        font-family: var(--font-paragraphs);
        font-size: 0.85rem;
        color: #666;
        text-decoration: none;
        transition: color 0.2s;
    }

    .filter-list-v li a:hover,
    .filter-list-v li a.active {
        color: var(--color-green);
        font-weight: 500;
    }

    .color-options {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
    }

    .color-swatch {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: block;
        transition: transform 0.2s;
        position: relative;
    }

    .color-swatch:hover {
        transform: scale(1.15);
    }

    .color-swatch.active {
        box-shadow:
            0 0 0 2px #fff,
            0 0 0 4px var(--color-green);
    }

    .talla-options {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
    }

    .talla-box {
        padding: 0.5rem 1rem;
        border: 1px solid #ddd;
        font-family: var(--font-paragraphs);
        font-size: 0.8rem;
        color: #333;
        text-decoration: none;
        transition: all 0.2s;
    }

    .talla-box:hover,
    .talla-box.active {
        border-color: #121212;
        background: #121212;
        color: #fff;
    }

    .drawer-footer {
        padding: 1.5rem 2rem;
        border-top: 1px solid #eee;
    }

    .btn-clear {
        display: block;
        text-align: center;
        padding: 1rem;
        background: #f4f4f4;
        color: #666;
        text-decoration: none;
        font-family: var(--font-paragraphs);
        font-size: 0.8rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        transition: background 0.2s;
    }

    .btn-clear:hover {
        background: #eee;
        color: #121212;
    }

    /* Media Queries */
    @media (max-width: 1200px) {
        .grid-4x3 {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @media (max-width: 768px) {
        .category-banner {
            height: 350px;
            justify-content: center;
            align-items: flex-end;
            padding-bottom: 2rem;
        }
        .banner-content {
            padding-left: 0;
            text-align: center;
            max-width: 90%;
        }
        .banner-overlay {
            background: rgba(0, 0, 0, 0.35);
        }
        .grid-4x3 {
            grid-template-columns: repeat(2, 1fr);
        }
        .filter-bar {
            flex-direction: column;
            gap: 1.5rem;
            align-items: flex-start;
        }
        .filter-right {
            width: 100%;
            justify-content: space-between;
        }
        .sort-dropdown {
            flex-grow: 1;
        }
    }

    @media (max-width: 480px) {
        .grid-4x3 {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

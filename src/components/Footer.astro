---
import { Image } from "astro:assets";
import ReviewsSection from "./ReviewsSection";
import BlogHome from "./BlogHome.astro";
import InstagramReels from "./InstagramReels";
import { getMenu, PUBLIC_WP_URL } from "../lib/woocommerce";

const menuCustomer = await getMenu("atencion-al-cliente");
const menuAbout = await getMenu("nosotros");
const menuLegal = await getMenu("legal");

function flattenCategoryUrl(url: string) {
    if (!url) return "/";

    const domains = [
        "https://tienda.winstonandharrystore.com",
        "https://winstonandharrystore.com",
        PUBLIC_WP_URL,
    ];

    let clean = url;
    domains.forEach((d) => {
        if (d) clean = clean.replace(d, "");
    });

    if (clean.includes("/product-category/")) {
        const segments = clean.split("/").filter(Boolean);
        const lastSegment = segments[segments.length - 1];
        return `/categoria/${lastSegment}/`;
    }

    if (!clean || clean === "" || clean === "/") return "/";
    if (!clean.startsWith("/")) clean = "/" + clean;
    return clean;
}
---

<footer id="footer" class="footer">
    <!-- Reviews Section moved to footer -->
    <ReviewsSection client:visible />

    <!-- Blog Section -->
    <BlogHome />

    <!-- Instagram Reels Section -->
    <InstagramReels client:visible />

    <!-- Barra Newsletter -->
    <div class="footer-newsletter-bar">
        <div class="container newsletter-container">
            <div class="newsletter-left">
                <span class="newsletter-text"
                    >SUSCRÍBETE Y OBTEN 10% DE DESCUENTO</span
                >
                <button id="newsletter-toggle" class="newsletter-button"
                    >SUSCRIBIRME</button
                >
            </div>
            <div class="newsletter-social">
                <a
                    href="https://www.instagram.com/winstonandharrystore/"
                    class="social-square"
                    aria-label="Instagram"
                    target="_blank"
                >
                    <i class="fa-brands fa-instagram"></i>
                </a>
                <a
                    href="https://www.tiktok.com/@winstonandharrystore"
                    class="social-square"
                    aria-label="TikTok"
                    target="_blank"
                >
                    <i class="fa-brands fa-tiktok"></i>
                </a>
                <a
                    href="https://www.facebook.com/winstonandharrystore"
                    class="social-square"
                    aria-label="Facebook"
                    target="_blank"
                >
                    <i class="fa-brands fa-facebook-f"></i>
                </a>
                <a
                    href="https://www.threads.com/@winstonandharrystore"
                    class="social-square"
                    aria-label="Threads"
                    target="_blank"
                >
                    <i class="fa-brands fa-threads"></i>
                </a>
            </div>
        </div>

        <!-- Formulario Suscripción Acordeón -->
        <div id="newsletter-form-container" class="newsletter-form-container">
            <div class="container">
                <form id="subscribe-form" class="subscribe-form">
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="reg-email">Correo Electrónico *</label>
                            <input
                                type="email"
                                id="reg-email"
                                name="email"
                                required
                                placeholder="tu@email.com"
                            />
                        </div>
                        <div class="form-group">
                            <label for="reg-phone"
                                >Número de teléfono móvil *</label
                            >
                            <input
                                type="tel"
                                id="reg-phone"
                                name="phone"
                                required
                                placeholder="+57 --- --- ----"
                            />
                        </div>
                        <div class="form-group">
                            <label for="reg-fname">Nombre *</label>
                            <input
                                type="text"
                                id="reg-fname"
                                name="first_name"
                                required
                                placeholder="Tu nombre"
                            />
                        </div>
                        <div class="form-group">
                            <label for="reg-lname">Apellido *</label>
                            <input
                                type="text"
                                id="reg-lname"
                                name="last_name"
                                required
                                placeholder="Tu apellido"
                            />
                        </div>
                    </div>
                    <div class="form-checkbox">
                        <input
                            type="checkbox"
                            id="reg-privacy"
                            name="privacy"
                            required
                        />
                        <label for="reg-privacy"
                            >Autorizo el tratamiento de mis datos personales
                            teniendo en cuenta la Política de Tratamiento de
                            Datos de Winston & Harry. Aplican T&C</label
                        >
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="form-submit">ENVIAR</button
                        >
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="container footer-grid">
        <!-- Columna 1: Logo e Info -->
        <div class="footer-column brand-info">
            <div class="footer-logo">
                <a href="/" class="logo">
                    <Image
                        src="https://tienda.winstonandharrystore.com/wp-content/uploads/2020/12/logo-w-h-vertical.png"
                        alt="Winston & Harry Logo"
                        width={250}
                        height={250}
                        referrerpolicy="no-referrer"
                        loading="lazy"
                        decoding="async"
                    />
                </a>
            </div>
            <p class="brand-description">
                Nuestros productos son orgullosamente hechos a mano, cuidando
                las tradiciones que nuestros artesanos colombianos han
                conservado a lo largo de varias generaciones.
            </p>
            <div class="brand-contact">
                <p>
                    <a href="/contacto" class="contact-link"
                        >Bogotá, Colombia</a>
                </p>
                <p>
                    Teléfono: <a href="tel:+573103075540" class="contact-link"
                        >+57 310 3075540</a>
                </p>
                <p>
                    <a
                        href="mailto:info@winstonandharrystore.com"
                        class="contact-link">info@winstonandharrystore.com</a>
                </p>
            </div>
        </div>

        <!-- Columna 2: Atención al Cliente -->
        <div class="footer-column">
            <h3 class="footer-title">ATENCIÓN AL CLIENTE</h3>
            <ul class="footer-links">
                {
                    menuCustomer.length > 0 ? (
                        menuCustomer.map((item: any) => (
                            <li>
                                <a
                                    href={flattenCategoryUrl(item.url)}
                                    set:html={item.title}
                                />
                            </li>
                        ))
                    ) : (
                        <>
                            <li>
                                <a href="/contacto">Contáctanos</a>
                            </li>
                            <li>
                                <a href="/contacto">Tiendas</a>
                            </li>
                        </>
                    )
                }
            </ul>
        </div>

        <!-- Columna 3: Nosotros -->
        <div class="footer-column">
            <h3 class="footer-title">NOSOTROS</h3>
            <ul class="footer-links">
                {
                    menuAbout.length > 0 ? (
                        menuAbout.map((item: any) => (
                            <li>
                                <a
                                    href={flattenCategoryUrl(item.url)}
                                    set:html={item.title}
                                />
                            </li>
                        ))
                    ) : (
                        <>
                            <li>
                                <a href="/categoria/zapatos">Zapatos</a>
                            </li>
                            <li>
                                <a href="/categoria/accesorios">Accesorios</a>
                            </li>
                            <li>
                                <a href="/categoria/maletas">Maletas</a>
                            </li>
                            <li>
                                <a href="/categoria/mascotas">Mascotas</a>
                            </li>
                            <li>
                                <a href="/categoria/ropa">Ropa</a>
                            </li>
                            <li>
                                <a href="/guia-de-tallas">Guía de tallas</a>
                            </li>
                        </>
                    )
                }
            </ul>
        </div>

        <!-- Columna 4: Legal -->
        <div class="footer-column">
            <h3 class="footer-title">LEGAL</h3>
            <ul class="footer-links">
                {
                    menuLegal.length > 0 ? (
                        menuLegal.map((item: any) => (
                            <li>
                                <a
                                    href={flattenCategoryUrl(item.url)}
                                    set:html={item.title}
                                />
                            </li>
                        ))
                    ) : (
                        <>
                            <li>
                                <a href="/politica-privacidad-proteccion-datos">
                                    Política de privacidad
                                </a>
                            </li>
                            <li>
                                <a href="/terminos-condiciones">
                                    Términos y condiciones
                                </a>
                            </li>
                            <li>
                                <a href="/politica-costos-envio">
                                    Política de envíos
                                </a>
                            </li>
                        </>
                    )
                }
            </ul>
        </div>
    </div>

    <!-- Barra Inferior -->
    <div class="footer-bottom">
        <div class="container">
            <p>
                WINSTON & HARRY 2026 UN DESARROLLO DE <a
                    href="https://goestrategiacreativa.com/"
                    target="_blank"
                    class="agency">GO Agency.</a
                >
            </p>
        </div>
    </div>

    <!-- Botón Volver Arriba -->
    <button
        id="scroll-to-top"
        class="scroll-top-btn"
        aria-label="Volver arriba"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="m18 15-6-6-6 6"></path></svg
        >
    </button>
</footer>

<script is:inline>
    const scrollBtn = document.getElementById("scroll-to-top");
    window.addEventListener("scroll", () => {
        if (window.pageYOffset > 300) {
            scrollBtn.classList.add("visible");
        } else {
            scrollBtn.classList.remove("visible");
        }
    });
    scrollBtn.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
    });

    // Toggle Formulario Newsletter
    const newsletterToggle = document.getElementById("newsletter-toggle");
    const newsletterForm = document.getElementById("newsletter-form-container");

    if (newsletterToggle && newsletterForm) {
        newsletterToggle.addEventListener("click", () => {
            newsletterForm.classList.toggle("open");
            if (newsletterForm.classList.contains("open")) {
                newsletterToggle.textContent = "CERRAR";
            } else {
                newsletterToggle.textContent = "SUSCRIBIRME";
            }
        });
    }

    const subscribeForm = document.getElementById("subscribe-form");
    if (subscribeForm) {
        subscribeForm.addEventListener("submit", async (e) => {
            e.preventDefault();

            const btn = subscribeForm.querySelector(".form-submit");
            const originalText = btn.textContent;
            btn.textContent = "ENVIANDO...";
            btn.disabled = true;

            const data = new FormData(subscribeForm);
            const email = data.get("email")?.toString().trim() || "";
            const phone = data.get("phone")?.toString().trim() || "";
            const first_name = data.get("first_name")?.toString().trim() || "";
            const last_name = data.get("last_name")?.toString().trim() || "";

            const PORTAL_ID = "22727126";
            const FORM_ID = "0723b68c-0294-4e45-aa9f-4fa00a102f50";
            const HS_URL = `https://api.hsforms.com/submissions/v3/integration/submit/${PORTAL_ID}/${FORM_ID}`;

            const payload = {
                fields: [
                    { objectTypeId: "0-1", name: "email", value: email },
                    { objectTypeId: "0-1", name: "mobilephone", value: phone },
                    {
                        objectTypeId: "0-1",
                        name: "firstname",
                        value: first_name,
                    },
                    { objectTypeId: "0-1", name: "lastname", value: last_name },
                ],
                context: {
                    pageUri: window.location.href,
                    pageName: document.title,
                },
                legalConsentOptions: {
                    consent: {
                        consentToProcess: true,
                        text: "Autorizo el tratamiento de mis datos personales teniendo en cuenta la Política de Tratamiento de Datos de Winston & Harry.",
                    },
                },
            };

            try {
                const res = await fetch(HS_URL, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload),
                });

                if (res.ok) {
                    // Éxito — mostrar mensaje inline sin alert()
                    subscribeForm.innerHTML = `
                        <p style="color:#155338;font-weight:600;text-align:center;padding:1.5rem 0;font-size:1rem;letter-spacing:0.05em;">
                            ¡Gracias por suscribirte! Pronto recibirás nuestras novedades.
                        </p>`;
                    setTimeout(() => {
                        newsletterForm.classList.remove("open");
                        newsletterToggle.textContent = "SUSCRIBIRME";
                    }, 3000);
                } else {
                    const err = await res.json().catch(() => ({}));
                    console.error("HubSpot Integration Error:", err);
                    throw new Error("Error en la suscripción");
                }
            } catch (err) {
                console.error(err);
                alert("Hubo un problema. Por favor, inténtalo de nuevo.");
                btn.textContent = originalText;
                btn.disabled = false;
            }
        });
    }
</script>

<style>
    .footer {
        background-color: #fff;
        color: #666;
        padding: 0;
        font-family: var(--font-paragraphs);
    }

    .footer-newsletter-bar {
        background-color: var(--color-green, #155338);
        padding: 1.5rem 0;
    }

    .newsletter-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .newsletter-left {
        display: flex;
        align-items: center;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .newsletter-text {
        color: #fff;
        font-family: var(--font-titles);
        font-weight: 700;
        letter-spacing: 1px;
        font-size: 1.1rem;
    }

    .newsletter-button {
        background-color: var(--color-beige, #b1915f);
        color: #fff;
        border: none;
        padding: 0.8rem 3rem;
        font-family: var(--font-paragraphs);
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: var(--transition-smooth, top 0.3s ease);
        letter-spacing: 3px;
    }

    .newsletter-button:hover {
        background-color: #fff;
        color: var(--color-beige, #b1915f);
    }

    .newsletter-social {
        display: flex;
        gap: 1rem;
    }

    .social-square {
        width: 35px;
        height: 35px;
        background-color: var(--color-beige, #b1915f);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 700;
        font-size: 0.8rem;
        transition: var(--transition-smooth, all 0.3s);
        border-radius: 4px;
        text-decoration: none;
    }

    .social-square:hover {
        background-color: #fff;
        color: var(--color-green, #155338);
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr 1fr;
        gap: 2rem;
        padding-top: 4rem;
        padding-bottom: 0rem;
    }

    .brand-info {
        padding-right: 2rem;
    }

    .footer-logo {
        padding-bottom: 20px;
    }

    .footer-logo :global(img) {
        width: 250px;
        height: auto;
        display: block;
    }

    .brand-description {
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 2rem;
        color: #888;
    }

    .brand-contact p {
        margin: 0.5rem 0;
        font-size: 0.9rem;
        color: #999;
    }

    .contact-link {
        color: inherit;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .contact-link:hover {
        color: var(--color-green, #155338);
    }

    .footer-title {
        color: var(--color-green, #155338);
        font-size: 0.9rem;
        font-weight: 800;
        margin-bottom: 1rem;
        letter-spacing: 1px;
    }

    .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-links li {
        margin-bottom: 1rem;
    }

    .footer-links a {
        color: #999;
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
    }

    .footer-links a:hover {
        color: var(--color-green, #155338);
    }

    .italic-link {
        font-style: italic;
    }

    .footer-bottom {
        border-top: 1px solid #f9f9f9;
        padding: 1rem 0;
        text-align: center;
        background-color: #fff;
    }

    .footer-bottom p {
        font-size: 0.75rem;
        letter-spacing: 1px;
        color: #aaa;
        text-transform: uppercase;
    }

    .agency {
        color: var(--color-beige, #b1915f);
        font-weight: bold;
    }

    /* Botón Volver Arriba */
    .scroll-top-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 45px;
        height: 45px;
        background: #fff;
        border: none;
        border-radius: 50%;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s;
        z-index: 99;
        color: #333;
    }

    .scroll-top-btn.visible {
        opacity: 1;
        visibility: visible;
    }

    .scroll-top-btn:hover {
        transform: translateY(-5px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
    }

    @media (max-width: 992px) {
        .footer-grid {
            grid-template-columns: repeat(2, 1fr);
            padding: 2rem;
        }
        .newsletter-text {
            color: #fff;
            font-family: var(--font-titles);
            font-weight: 700;
            letter-spacing: 1px;
            font-size: 0.98em;
        }

        .newsletter-left {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .newsletter-button {
            width: 100%;
        }
        .subscribe-form {
            padding: 0rem !important;
            color: #fff;
        }
        .form-group {
            gap: 0.5rem;
        }
        .form-submit {
            padding: 2rem;
        }
        .form-checkbox {
            margin-bottom: 1rem !important;
        }
    }

    @media (max-width: 600px) {
        .footer-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Estilos Formulario Newsletter */
    .newsletter-form-container {
        max-height: 0;
        overflow: hidden;
        transition:
            max-height 0.6s cubic-bezier(0.4, 0, 0.2, 1),
            padding 0.6s ease;
        background-color: var(--color-green, #155338);
    }

    .newsletter-form-container.open {
        max-height: 800px;
        padding: 2rem 0rem;
    }

    .subscribe-form {
        padding: 2.5rem 15rem;
        color: #fff;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .form-group label {
        font-family: var(--font-titles);
        font-size: 0.75rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--color-beige);
    }

    .form-group input {
        background: #fff;
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 1rem;
        color: #000;
        font-family: var(--font-paragraphs);
        font-size: 0.9rem;
        transition: all 0.3s ease;
        border-radius: 0;
    }

    .form-group input::placeholder {
        color: #999;
    }

    .form-group input:focus {
        outline: none;
        border-color: var(--color-beige);
        background: rgba(255, 255, 255, 0.1);
    }

    .form-checkbox {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        margin-bottom: 3rem;
        max-width: 865px;
    }

    .form-checkbox input {
        margin-top: 0rem;
        accent-color: var(--color-beige);
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .form-checkbox label {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.6;
        cursor: pointer;
        transition: color 0.3s;
    }

    .form-checkbox input:checked + label {
        color: #fff;
    }

    .form-actions {
        display: flex;
        justify-content: center;
    }

    .form-submit {
        background-color: var(--color-beige, #b1915f);
        color: #fff;
        border: none;
        padding: 1.2rem 5rem;
        font-family: var(--font-titles);
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        letter-spacing: 3px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        text-transform: uppercase;
    }

    .form-submit:hover {
        background-color: #fff;
        color: var(--color-green);
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    }

    .form-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    @media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .newsletter-form-container.open {
            max-height: 1200px;
            padding: 2rem 0rem 0rem 0rem !important;
        }

        .form-submit {
            width: 100%;
            padding: 1rem;
        }
    }
</style>

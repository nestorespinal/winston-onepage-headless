---
import { getHeroSlides } from "../lib/hero";
import { getOptimizedUrl, getImageSrcSet } from "../utils/image";

// Fetch dynamic data con timeout de 3s para no bloquear el SSR
function withTimeout<T>(promise: Promise<T>, ms: number, fallback: T): Promise<T> {
  return Promise.race([
    promise,
    new Promise<T>((resolve) => setTimeout(() => resolve(fallback), ms)),
  ]);
}
const result = await withTimeout(getHeroSlides(), 3000, { slides: [], slots: 0 });

const allSlides = result.slides || [];
const slots = result.slots || 1;

// Limitamos las diapositivas al número de "slots" definido
const displaySlides = allSlides.slice(0, slots);

// Si no hay diapositivas, usamos una por defecto para no romper el diseño
const finalSlides = displaySlides.length > 0 ? displaySlides : [
    {
        title: "Ropa y Zapatos de Cuero para Hombre",
        subtitle: "Hechos a mano en Colombia y diseñados para durar.",
        media_url: "/videos/hero-video.mp4",
        is_video: true,
        btn1_title: "Explorar Colección",
        btn1_link: "/tienda",
        btn2_title: "Conoce Nuestra Historia",
        btn2_link: "#nosotros"
    }
];
---

<section id="inicio" class="hero swiper hero-slider">
    <div class="swiper-wrapper">
        {finalSlides.map((slide) => (
            <div class="swiper-slide">
                <div class="image-background">
                    {slide.is_video ? (
                        <>
                            {/* Poster como <img> real: el browser lo descarga con máxima prioridad (LCP fix) */}
                            <img
                                src="/images/banner-winston-and-harry-maletas.webp"
                                class="hero-bg-image hero-poster"
                                alt="Winston & Harry — Ropa y zapatos de cuero para hombre"
                                fetchpriority="high"
                                loading="eager"
                                decoding="sync"
                                width="1920"
                                height="1080"
                            />
                            {/* Video SIN poster (ya tenemos el <img> encima) — se superpone al cargar */}
                            <video
                                class="hero-bg-image hero-video-layer"
                                autoplay
                                muted
                                playsinline
                                preload="none"
                            >
                                <source src={slide.media_url} type="video/mp4" />
                            </video>
                        </>
                    ) : (
                        <img 
                            src={getOptimizedUrl(slide.media_url, { width: 1920 })} 
                            srcset={getImageSrcSet(slide.media_url, [800, 1200, 1920])}
                            sizes="100vw"
                            class="hero-bg-image" 
                            alt={slide.title}
                            loading="eager"
                            fetchpriority="high"
                            decoding="sync"
                        />
                    )}
                    <div class="overlay"></div>
                </div>

                <div class="hero-content">
                    <h1 class="hero-title" set:html={slide.title}></h1>
                    <p class="hero-subtitle" set:html={slide.subtitle}></p>
                    <div class="hero-actions">
                        {slide.btn1_title && (
                            <a href={slide.btn1_link} class="btn-primary" set:html={slide.btn1_title}></a>
                        )}
                        {slide.btn2_title && (
                            <a href={slide.btn2_link} class="btn-secondary" set:html={slide.btn2_title}></a>
                        )}
                    </div>
                </div>
            </div>
        ))}
    </div>
    
    <!-- Controles del Slider -->
    <div class="swiper-pagination"></div>
</section>

<!-- Swiper CSS: no bloqueante (media print trick) -->
<link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
    media="print"
    onload="this.media='all'"
/>
<!-- Swiper JS: diferido, no bloquea el hilo principal -->
<script defer src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script is:inline>
    function initHeroSlider() {
        if (typeof Swiper === 'undefined') {
            // Swiper aún no cargó (defer), reintentamos en 100ms
            setTimeout(initHeroSlider, 100);
            return;
        }

        const swiperEl = document.querySelector('.hero-slider');
        if (!swiperEl) return;
        if (swiperEl._swiperInit) return;
        swiperEl._swiperInit = true;

        const swiper = new Swiper('.hero-slider', {
            effect: 'fade',
            fadeEffect: { crossFade: true },
            loop: true,
            speed: 1500,
            autoplay: { delay: 6000, disableOnInteraction: false },
            pagination: { el: '.swiper-pagination', clickable: true },
            on: {
                init: function () { checkVideo(this); },
                slideChange: function () { checkVideo(this); }
            }
        });

        function checkVideo(instance) {
            const activeSlide = instance.slides[instance.activeIndex];
            const video = activeSlide?.querySelector('video');
            const poster = activeSlide?.querySelector('.hero-poster');

            if (video) {
                instance.autoplay.stop();
                video.currentTime = 0;
                video.play().catch(() => {});

                // Cuando el video esté reproduciéndose, ocultamos el poster
                video.addEventListener('playing', () => {
                    if (poster) poster.style.opacity = '0';
                }, { once: true });

                video.onended = () => {
                    if (poster) poster.style.opacity = '1';
                    instance.slideNext();
                    instance.autoplay.start();
                };
            } else {
                instance.autoplay.start();
            }
        }
    }

    document.addEventListener('astro:page-load', initHeroSlider);
    document.addEventListener('DOMContentLoaded', initHeroSlider);
</script>

<style>
    .hero {
        position: sticky;
        top: 90px;
        margin-top: 90px;
        height: 100vh;
        width: 100%;
        overflow: hidden;
        background-color: #000;
        z-index: 1;
        transition: top 0.3s ease-in-out;
    }

    :global(body.is-header-hidden) .hero {
        top: 0;
    }

    .swiper-slide {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .image-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.35);
        z-index: 1;
    }

    .hero-bg-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    /* El poster (img) siempre visible debajo, el video encima con transición */
    .hero-poster {
        z-index: 0;
        transition: opacity 0.5s ease;
    }

    .hero-video-layer {
        z-index: 1;
        opacity: 1;
        transition: opacity 0.5s ease;
    }

    .hero-content {
        position: relative;
        z-index: 10;
        text-align: center;
        max-width: 900px;
        padding: 0 2rem;
        margin-top: 25vh; /* Ajustado para que se vea mejor centrado en el slider */
        animation: fadeInUp 1.5s ease-out forwards;
    }

    .hero-title {
        font-family: var(--font-titles);
        color: var(--color-white);
        font-size: 1.25rem;
        font-weight: 700;
        line-height: 1.4;
        margin-bottom: 2rem;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .hero-subtitle {
        font-family: var(--font-paragraphs);
        color: var(--color-white);
        font-size: 0.85rem;
        max-width: 700px;
        margin: 0 auto 3.5rem;
        line-height: 1.6;
        text-transform: none;
        letter-spacing: 0.5px;
    }

    .hero-actions {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary, .btn-secondary {
        display: inline-block;
        padding: 1rem 2.5rem;
        font-family: var(--font-titles);
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: none;
        cursor: pointer;
        min-width: 240px;
        border-radius: 0;
    }

    .btn-primary {
        background-color: #155338;
        color: #efefef;
    }

    .btn-secondary {
        background-color: var(--color-beige);
        color: #efefef;
    }

    .btn-primary:hover {
        background-color: var(--color-beige);
        transform: translateY(-3px);
    }

    .btn-secondary:hover {
        background-color: var(--color-green);
        transform: translateY(-3px);
    }

    /* Estilos Swiper */
    .swiper-pagination {
        bottom: 40px !important;
    }

    :global(.swiper-pagination-bullet) {
        background: #fff !important;
        opacity: 0.5;
    }

    :global(.swiper-pagination-bullet-active) {
        background: var(--color-beige) !important;
        opacity: 1;
        width: 30px;
        border-radius: 4px;
        transition: all 0.3s ease;
    }

    @keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(40px); }
        100% { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 992px) {
        .hero {
            height: 85vh;
            top: 65px;
            margin-top: 65px;
        }

        .hero-title { font-size: 1.25rem; }
        .hero-content { margin-top: 15vh; }
        .btn-primary, .btn-secondary { width: 100%; min-width: unset; }
    }
</style>

---
import { Image } from "astro:assets";
import { getMenu, PUBLIC_WP_URL } from "../lib/woocommerce";
import UserStatus from "./auth/UserStatus";
import { getOptimizedUrl, getImageSrcSet } from "../utils/image";

// El slug de WordPress para "Menú principal" comúnmente es "menu-principal"
const menuItems = await getMenu("menu-principal");

function buildMenuTree(items: any[]) {
    if (!items || !items.length) return [];
    const itemMap: any = {};
    items.forEach((item) => {
        itemMap[item.id] = { ...item, children: [] };
    });
    const tree: any[] = [];
    items.forEach((item) => {
        const parentId = parseInt(item.parent as string, 10);
        if (parentId !== 0 && itemMap[parentId]) {
            itemMap[parentId].children.push(itemMap[item.id]);
        } else {
            tree.push(itemMap[item.id]);
        }
    });
    return tree;
}

const menuTree = buildMenuTree(menuItems);

function flattenCategoryUrl(url: string) {
    if (!url) return "/";
    
    // Lista de dominios que pueden venir en las URLs de WordPress
    const domains = [
        "https://tienda.winstonandharrystore.com",
        "https://winstonandharrystore.com",
        PUBLIC_WP_URL
    ];
    
    let clean = url;
    domains.forEach(d => {
        if (d) clean = clean.replace(d, "");
    });

    // Caso de categoría de producto (WooCommerce predeterminado)
    if (clean.includes("/product-category/")) {
        const segments = clean.split("/").filter(Boolean);
        const lastSegment = segments[segments.length - 1];
        return `/categoria/${lastSegment}`;
    }

    // Asegurar que no quede "vacio" o "//"
    if (!clean || clean === "" || clean === "/") return "/";
    
    // Normalizar a barra inicial si no la tiene
    if (!clean.startsWith("/")) clean = "/" + clean;

    clean = clean.replace(/\/$/, '');
    
    return clean;
}
---

<header class="header">
    <div class="header-inner">
        <!-- Parte Izquierda: Menú y Buscar -->
        <div class="header-left">
            <button
                class="burger-menu"
                id="burger-menu"
                aria-label="Abrir menú"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <button
                class="action-btn search-btn header-search-desktop"
                id="search-btn-left"
                aria-label="Buscar"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
            </button>
        </div>

        <!-- Parte Central: Logo -->
        <a href="/" class="logo">
            <img
                src={getOptimizedUrl(`${PUBLIC_WP_URL}/wp-content/uploads/2020/12/logo-w-h-vertical.png`, { width: 440 })}
                srcset={getImageSrcSet(`${PUBLIC_WP_URL}/wp-content/uploads/2020/12/logo-w-h-vertical.png`, [220, 440])}
                alt="Winston & Harry Logo"
                width="220"
                height="220"
                referrerpolicy="no-referrer"
                loading="eager"
                decoding="async"
            />
        </a>

        <!-- Parte Derecha: Acciones -->
        <div class="header-right">
            <button
                class="action-btn cart-btn-new header-cart-mobile"
                id="cart-btn-desktop"
                aria-label="Carrito"
            >
                <div class="cart-icon-wrapper">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"
                        ></path>
                        <path d="M3 6h18"></path>
                        <path d="M16 10a4 4 0 0 1-8 0"></path>
                    </svg>
                    <span class="cart-count" id="cart-count">0</span>
                </div>
            </button>

            <UserStatus client:load />

            <div class="header-actions-desktop">
                <a
                    href="/lista-de-deseos"
                    class="action-btn"
                    aria-label="Ver Favoritos"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                        ></path>
                    </svg>
                    <span class="fav-count" id="fav-count">0</span>
                </a>
            </div>
        </div>
    </div>
</header>

<div class="menu-overlay" id="menu-overlay"></div>

<div class="mobile-nav" id="mobile-nav">
    <ul class="mobile-links">
        {
            menuTree && menuTree.length > 0 ? (
                menuTree.map((item: any) => (
                    <li
                        class={`menu-item ${item.children.length > 0 ? "has-submenu" : ""}`}
                    >
                        <div class="menu-link-wrapper">
                            <a
                                href={flattenCategoryUrl(item.url)}
                                class="mobile-link"
                                set:html={item.title}
                            />
                            {item.children.length > 0 && (
                                <button
                                    class="submenu-toggle"
                                    aria-expanded="false"
                                    aria-label={`Abrir submenú de ${item.title}`}
                                >
                                    <svg
                                        viewBox="0 0 24 24"
                                        width="16"
                                        height="16"
                                        stroke="currentColor"
                                        stroke-width="1.5"
                                        fill="none"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <polyline points="6 9 12 15 18 9" />
                                    </svg>
                                </button>
                            )}
                        </div>
                        {item.children.length > 0 && (
                            <ul class="submenu">
                                {item.children.map((child: any) => (
                                    <li>
                                        <a
                                            href={flattenCategoryUrl(child.url)}
                                            class="mobile-sublink"
                                            set:html={child.title}
                                        />
                                    </li>
                                ))}
                            </ul>
                        )}
                    </li>
                ))
            ) : (
                <>
                    <li>
                        <a href="/" class="mobile-link">
                            Inicio
                        </a>
                    </li>
                    <li>
                        <a href="/#tienda" class="mobile-link">
                            Tienda
                        </a>
                    </li>
                    <li>
                        <a href="/#nosotros" class="mobile-link">
                            Nosotros
                        </a>
                    </li>
                    <li>
                        <a href="/#contacto" class="mobile-link">
                            Contacto
                        </a>
                    </li>
                </>
            )
        }
    </ul>

    <div class="mobile-actions">
        <a href="/lista-de-deseos" class="mobile-action-item">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                ></path></svg
            >
            <span>Lista de Deseos (<span id="fav-count-mobile">0</span>)</span>
        </a>
        <button class="mobile-action-item cart-btn-new" id="cart-btn-mobile">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"
                ></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"
                ></path></svg
            >
            <span>Carrito (<span id="cart-count-mobile">0</span>)</span>
        </button>
    </div>

    <div class="menu-footer">
        <a href="/contacto" class="help-link">¿Cómo podemos ayudarle?</a>
    </div>
</div>

<!-- Cart Drawer Replaced by SideCart.tsx in Layout -->

<script>
    import { isCartOpen, cartItems, isSearchOpen } from "../store/cart";
    const burgerBtn = document.getElementById("burger-menu");
    const searchBtn = document.getElementById("search-btn-left");
    const searchBtnMobile = document.getElementById("search-btn-mobile");
    const menuOverlay = document.getElementById("menu-overlay");
    const mobileNav = document.getElementById("mobile-nav");
    const mobileLinks = document.querySelectorAll(
        ".mobile-link, .mobile-sublink",
    );

    const cartBtns = document.querySelectorAll(".cart-btn-new");

    function toggleMenu(open: boolean) {
        if (!mobileNav || !menuOverlay) return;
        if (open) {
            mobileNav.classList.add("active");
            menuOverlay.classList.add("active");
            burgerBtn?.classList.add("open");
            document.body.style.overflow = "hidden";
        } else {
            mobileNav.classList.remove("active");
            menuOverlay.classList.remove("active");
            burgerBtn?.classList.remove("open");
            document.body.style.overflow = "";
        }
    }

    // Cart toggle handled by isCartOpen atom

    if (burgerBtn)
        burgerBtn.addEventListener("click", () => {
            const isOpen = mobileNav?.classList.contains("active");
            toggleMenu(!isOpen);
        });

    if (searchBtn) {
        searchBtn.addEventListener("click", () => {
            toggleMenu(false);
            isSearchOpen.set(true);
        });
    }

    if (searchBtnMobile) {
        searchBtnMobile.addEventListener("click", () => {
            toggleMenu(false);
            isSearchOpen.set(true);
        });
    }

    cartBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            toggleMenu(false);
            isCartOpen.set(true);
        });
    });

    // Close cart via overlay only in Header script (main close is in SideCart.tsx)

    if (menuOverlay) {
        menuOverlay.addEventListener("click", () => {
            toggleMenu(false);
            isCartOpen.set(false);
        });
    }

    mobileLinks.forEach((link) => {
        link.addEventListener("click", () => {
            // No cerrar el menú si se hace click en el toggle del submenú, pero mobile-link es solo el texto así que esto está bien.
            toggleMenu(false);
        });
    });

    const submenuToggles = document.querySelectorAll(".submenu-toggle");
    submenuToggles.forEach((toggle) => {
        toggle.addEventListener("click", (e) => {
            e.preventDefault();
            e.stopPropagation();
            const parentLi = toggle.closest(".has-submenu");
            if (!parentLi) return;

            const isOpen = parentLi.classList.contains("open");

            // Cerrar todos los demás submenús al abrir otro
            document.querySelectorAll(".has-submenu").forEach((li) => {
                li.classList.remove("open");
                li.querySelector(".submenu-toggle")?.setAttribute(
                    "aria-expanded",
                    "false",
                );
            });

            if (!isOpen) {
                parentLi.classList.add("open");
                toggle.setAttribute("aria-expanded", "true");
            }
        });
    });

    // Redundant cart logic removed, now handled by Nanostores

    function updateFavCount() {
        const countSpans = [
            document.getElementById("fav-count"),
            document.getElementById("fav-count-mobile"),
        ];
        try {
            const favorites = JSON.parse(
                localStorage.getItem("wh_favorites") || "[]",
            );
            const count = favorites.length;
            countSpans.forEach((span) => {
                if (!span) return;
                const isMobile = span.id.includes("mobile");
                if (count > 0) {
                    span.textContent = count.toString();
                    span.style.display = isMobile ? "inline" : "flex";
                } else {
                    if (isMobile) {
                        span.textContent = "0";
                        span.style.display = "inline";
                    } else {
                        span.style.display = "none";
                    }
                }
            });
        } catch (e) {
            console.error("Error reading favorites", e);
        }
    }

    function updateCartTotal() {
        const cartCountSpans = [
            document.getElementById("cart-count"),
            document.getElementById("cart-count-mobile"),
        ];

        const cart = cartItems.get();
        const count = Object.values(cart).reduce(
            (sum: number, itemStr: any) => {
                if (!itemStr) return sum;
                try {
                    const item = JSON.parse(itemStr);
                    return sum + (item.quantity || 0);
                } catch (e) {
                    return sum;
                }
            },
            0,
        );

        cartCountSpans.forEach((span) => {
            if (!span) return;
            const isMobile = span.id.includes("mobile");
            if (count > 0) {
                span.textContent = count.toString();
                span.style.display = isMobile ? "inline" : "flex";
            } else {
                if (isMobile) {
                    span.textContent = "0";
                    span.style.display = "inline";
                } else {
                    span.style.display = "none";
                }
            }
        });
    }

    // Subscribe to cart changes
    cartItems.listen(() => {
        updateCartTotal();
    });

    window.addEventListener("storage", () => {
        updateFavCount();
        updateCartTotal();
    });

    window.addEventListener("cart-updated", updateCartTotal);

    document.addEventListener("astro:page-load", () => {
        updateFavCount();
        updateCartTotal();
    });

    // Efecto de ocultar Header al hacer scroll
    let lastScrollY = window.scrollY;
    const header = document.querySelector(".header");

    window.addEventListener("scroll", () => {
        if (mobileNav?.classList.contains("active")) return; // Prevent hiding header when menu is open

        if (window.scrollY > lastScrollY && window.scrollY > 100) {
            header?.classList.add("header-hidden");
            document.body.classList.add("is-header-hidden");
        } else {
            header?.classList.remove("header-hidden");
            document.body.classList.remove("is-header-hidden");
        }
        lastScrollY = window.scrollY;
    });

    updateFavCount();
    updateCartTotal();
</script>

<style is:global>
    .header {
        position: fixed; /* Cambiado de sticky a fixed para mejor control */
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1000;
        background-color: #ffffff;
        border-bottom: 1px solid #f0f0f0;
        padding: 1.2rem 0;
        transition: transform 0.3s ease-in-out;
    }

    .header-hidden {
        transform: translateY(-100%);
    }

    .header-inner {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        max-width: 1600px;
        margin: 0 auto;
        padding: 0 3rem;
        width: 100%;
    }

    /* Izquierda */
    .header-left {
        display: flex;
        align-items: center;
        gap: 2.5rem;
    }

    .burger-menu {
        background: none;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        transition: opacity 0.3s;
        width: 24px;
        height: 24px;
    }

    .burger-menu svg {
        width: 20px;
        height: 20px;
    }

    .burger-menu line {
        transition:
            transform 0.3s ease,
            opacity 0.3s ease;
        transform-origin: center;
        transform-box: fill-box;
    }

    /* SVG Lines order: 1=Top(6), 2=Middle(12), 3=Bottom(18) */
    .burger-menu.open line:nth-child(1) {
        transform: translateY(6px) rotate(45deg);
    }

    .burger-menu.open line:nth-child(2) {
        opacity: 0;
    }

    .burger-menu.open line:nth-child(3) {
        transform: translateY(-6px) rotate(-45deg);
    }

    .search-btn {
        background: none;
        border: none;
        cursor: pointer;
        display: flex !important;
        align-items: center;
        gap: 0.8rem;
        color: #333;
        padding: 5px;
        font-family: var(--font-paragraphs);
        transition: opacity 0.3s;
        pointer-events: auto !important;
    }

    .action-text {
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1.5px;
        font-weight: 500;
        margin-top: 2px;
    }

    .burger-menu:hover,
    .search-btn:hover,
    .action-btn:hover {
        opacity: 0.6;
    }

    /* Centro */
    .header-center {
        display: flex;
        justify-content: center;
    }

    .logo {
        display: block;
        width: 220px; /* Ajuste para que se vea premium y centrado */
        transition: transform 0.3s ease;
    }

    .logo img {
        width: 100%;
        height: auto;
        object-fit: contain;
    }

    /* Derecha */
    .header-right {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 2rem;
    }

    .action-btn {
        color: #333;
        position: relative;
        display: flex;
        align-items: center;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        gap: 0.5rem;
        transition: opacity 0.3s ease;
    }

    .header-cart-mobile {
        display: flex;
    }

    .fav-count {
        position: absolute;
        top: -6px;
        right: -10px;
        background-color: var(--color-beige);
        color: white;
        font-size: 0.65rem;
        font-weight: bold;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        display: none;
        align-items: center;
        justify-content: center;
    }

    .cart-btn {
        gap: 0.8rem;
    }

    .cart-icon-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .cart-count {
        position: absolute;
        top: -6px;
        right: -8px;
        background-color: var(--color-beige);
        color: white;
        font-size: 0.6rem;
        font-weight: bold;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        display: none;
        align-items: center;
        justify-content: center;
    }

    .cart-total {
        font-size: 0.8rem;
        font-weight: 500;
        color: #333;
        font-family: var(--font-paragraphs);
        letter-spacing: 0.5px;
    }

    /* Mobile Nav Drawer - LV STYLE BELOW HEADER */
    .mobile-nav {
        position: fixed;
        top: 75px; /* Altura estimada del header */
        left: 0;
        width: 30%;
        height: calc(100vh - 75px);
        background-color: #fff;
        transform: translateY(-100%);
        transition:
            transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
            visibility 0.4s;
        z-index: 950; /* Por detrás del header (1000) */
        display: flex;
        flex-direction: column;
        padding: 0;
        visibility: hidden;
        overflow: hidden; /* IMPORTANTE: El contenedor padre no scrollea */
    }

    .mobile-nav.active {
        transform: translateY(0);
        visibility: visible;
    }

    .mobile-actions {
        padding: 1rem 1rem;
        border-top: 1px solid #f0f0f0;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .mobile-action-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        color: #121212;
        text-decoration: none;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        font-family: var(--font-paragraphs);
    }
    .mobile-action-item svg {
        width: 18px;
        height: 18px;
    }

    .mobile-search-btn {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        background: none;
        border: none;
        border-bottom: 1px solid #121212;
        padding: 0.8rem 0;
        cursor: pointer;
        color: #121212;
        font-family: var(--font-titles);
        font-size: 0.75rem;
        letter-spacing: 2px;
        text-align: left;
    }
    .mobile-search-btn svg {
        color: #666;
    }

    .mobile-links {
        list-style: none;
        padding: 1.5rem 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem; /* El espacio se maneja a nivel del li */
        flex-grow: 1;
        overflow-y: auto; /* Solo scrollean los links */
    }

    .menu-item {
        display: flex;
        flex-direction: column;
    }

    .menu-link-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .submenu-toggle {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0px 10px;
        color: #121212;
        display: flex;
        align-items: center;
        transition: transform 0.3s ease;
    }

    .mobile-link {
        font-size: 0.95rem;
        font-weight: 400;
        color: #121212;
        text-decoration: none;
        display: block;
        font-family: var(--font-products);
        text-transform: uppercase;
        letter-spacing: 2px;
        flex-grow: 1;
    }

    .submenu {
        list-style: none;
        padding: 0;
        margin: 0;
        max-height: 0;
        overflow: hidden;
        transition:
            max-height 0.4s ease,
            margin-top 0.4s ease;
        background-color: #f6f6f6;
        margin-left: -3rem;
        margin-right: -3rem;
    }

    .has-submenu.open .submenu {
        margin-top: 1.5rem;
        max-height: 600px;
    }

    .has-submenu.open .submenu-toggle {
        transform: rotate(180deg);
    }

    .mobile-sublink {
        font-size: 0.85rem;
        font-weight: 300;
        color: #1a1a1a;
        text-decoration: none;
        display: block;
        padding: 1rem 3rem;
        font-family: var(--font-paragraphs);
        border-bottom: 1px solid #e9e9e9;
        transition: background-color 0.2s;
    }

    .submenu li:last-child .mobile-sublink {
        border-bottom: none;
    }

    .mobile-sublink:hover {
        background-color: #f0f0f0;
    }

    .menu-footer {
        padding: 2rem 3rem 4rem;
        margin-top: auto;
    }

    .header-actions-desktop {
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    @media (max-width: 768px) {
        .mobile-nav {
            top: 65px; /* Ajuste para mobile */
            height: calc(100vh - 65px);
            width: 100%;
        }
        .header-actions-desktop {
            display: none;
        }
        .header-cart-mobile {
            display: flex;
        }

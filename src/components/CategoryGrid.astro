---
import { getHomeCategories } from "../lib/categories";
import { getOptimizedUrl, getImageSrcSet } from "../utils/image";

// Obtenemos los datos dinámicos de la sección
const data = await getHomeCategories();

// Si no hay datos (error API), usamos un fallback para mantener la UI
const title = data?.title || "Ropa y zapatos para hombre";
const subtitle =
    data?.subtitle ||
    "Todo lo que necesita el hombre colombiano que viste con criterio. Ropa y cuero artesanal bajo un mismo sello.";
const categories = data?.categories || [];
---

<section class="category-grid">
    <div class="container text-center">
        <div class="category-header">
            <h2 class="category-title" set:html={title} />
            <div class="category-subtitle" set:html={subtitle} />
        </div>

        <div
            class={`grid-layout ${categories.length >= 4 ? "is-grid-4" : "is-flex-centered"}`}
        >
            {
                categories.map((category: any) => (
                    <a
                        href={`/categoria/${category.slug}`}
                        class="category-item"
                    >
                        <div class="category-image-wrapper">
                            <img
                                src={getOptimizedUrl(category.image || "/images/placeholder.jpg", { width: 400 })}
                                srcset={getImageSrcSet(category.image || "/images/placeholder.jpg", [300, 450, 600])}
                                sizes="(max-width: 768px) 50vw, 25vw"
                                alt={category.name}
                                class="category-image"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                        <h3 class="category-label">{category.name}</h3>
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .category-grid {
        padding: 4rem 0;
        background-color: #fff;
    }

    .category-header {
        max-width: 800px;
        margin: 0 auto 3rem;
        text-align: center;
        padding: 0 1rem;
    }

    .category-title {
        color: var(--color-green);
        font-size: 2rem;
        margin-bottom: 1.5rem;
        font-family: var(--font-titles);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        line-height: 1.2;
    }

    .category-subtitle {
        color: #333;
        font-size: 1rem;
        line-height: 1.6;
        font-family: var(--font-paragraphs);
        font-weight: 400;
        max-width: 600px;
        margin: 0 auto;
        text-transform: none;
    }

    .grid-layout {
        max-width: var(--container-max-width, 1400px);
        margin: 0 auto;
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 2rem;
    }

    /* Forzar el grid cuando hay 4 items */
    .grid-layout.is-grid-4 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
    }

    .category-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        transition: transform 0.4s ease;
    }

    /* Reset de anchos para el modo grid */
    .is-grid-4 .category-item {
        width: 100%;
    }

    .category-image-wrapper {
        width: 100%;
        aspect-ratio: 3 / 4;
        overflow: hidden;
        margin-bottom: 1.5rem;
        background-color: #f5f5f5;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    .category-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s cubic-bezier(0.2, 0, 0.2, 1);
    }

    .category-item:hover .category-image {
        transform: scale(1.08);
    }

    .category-label {
        font-family: var(--font-titles);
        font-size: 1.1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--color-green);
        margin: 0;
        text-align: center;
        transition: color 0.3s ease;
    }

    .category-item:hover .category-label {
        color: var(--color-beige);
    }

    @media (max-width: 1024px) {
        .category-grid {
            padding: 3rem 0;
        }
        
        .grid-layout.is-grid-4 {
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem 1.5rem;
            padding: 0 1.5rem;
        }

        .category-title {
            font-size: 1.75rem;
        }
    }

    @media (max-width: 480px) {
        .category-title {
            font-size: 1.6rem;
            letter-spacing: 1px;
        }

        .category-subtitle {
            font-size: 0.95rem;
        }

        .category-grid {
            padding: 2rem 0;
        }

        .grid-layout.is-grid-4 {
            gap: 1.5rem 1rem;
            padding: 0 1rem;
        }

        .category-label {
            font-size: 1rem;
        }
    }
</style>

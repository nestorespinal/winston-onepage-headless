---
import "../styles/global.css";
import SideCart from "../components/SideCart";
import SearchDrawer from "../components/SearchDrawer";
import CookieBanner from "../components/CookieBanner.astro";
import MetaPixel from "../components/MetaPixel.astro";
import { PUBLIC_WP_URL } from "../lib/woocommerce";

interface Props {
    title?: string;
    description?: string;
    image?: string;
    canonical?: string;
    seoData?: any;
}

const {
    title,
    description,
    image,
    canonical: customCanonical,
    seoData,
} = Astro.props;

import { sanitizeSEO } from "../lib/seo";
// IMPORTANTE: Cambia esta URL por tu dominio real de producción cuando lo tengas
const SITE_URL = "https://winstonandharrystore.com";
const currentPath = Astro.url.pathname;

const rawSeo = seoData
    ? sanitizeSEO(seoData, currentPath, SITE_URL)
    : {
          title: title || "Ropa y zapatos de cuero para hombre | Winston & Harry",
          description:
              description ||
              "Zapatos y ropa para hombre hechos a mano en Colombia. Cuero artesanal, diseño atemporal y garantía de por vida. Envío gratis.",
          canonical:
              customCanonical ||
              `${SITE_URL}${currentPath === "/" ? "" : currentPath}`,
          ogTitle: title || "Ropa y zapatos de cuero para hombre | Winston & Harry",
          ogDescription:
              description ||
              "Zapatos y ropa para hombre hechos a mano en Colombia. Cuero artesanal, diseño atemporal y garantía de por vida. Envío gratis.",
          ogImage: image || `${SITE_URL}/images/hero-poster.webp`,
          ogType: "website",
      };

// Asegurar que seo nunca sea null para TS
const seo = rawSeo || {
    title: "Winston & Harry",
    description: "Calzado Artesanal",
    canonical: SITE_URL,
    ogTitle: "Winston & Harry",
    ogDescription: "Calzado Artesanal",
    ogImage: `${SITE_URL}/favicon.png`,
    ogType: "website",
};
---

<!doctype html>
<html lang="es">
    <head>
        <!-- Google Tag Manager -->
        <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-NRK6FQ5N');</script>
        <!-- End Google Tag Manager -->
        <meta charset="UTF-8" />
        <meta name="description" content={seo.description} />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" href="/favicon.png" />
        <link rel="canonical" href={seo.canonical} />

        <link rel="preconnect" href="https://use.typekit.net" crossorigin />
        <link rel="dns-prefetch" href={PUBLIC_WP_URL} />
        <link rel="preload" href="https://use.typekit.net/lpl0lgn.css" as="style" />
        <link rel="stylesheet" href="https://use.typekit.net/lpl0lgn.css" />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
            integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
            crossorigin="anonymous"
            referrerpolicy="no-referrer"
            media="print"
            onload="this.media='all'"
        />

        <meta name="generator" content={Astro.generator} />
        <meta name="google-site-verification" content="9RFMzj77V6PFsieDNbn9QYGFbmVvJHT0-R5uT1Rn7UM" />
        <title>{seo.title}</title>

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content={seo.ogType} />
        <meta property="og:url" content={seo.canonical} />
        <meta property="og:title" content={seo.ogTitle || seo.title} />
        <meta
            property="og:description"
            content={seo.ogDescription || seo.description}
        />
        <meta property="og:image" content={seo.ogImage} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={seo.canonical} />
        <meta property="twitter:title" content={seo.ogTitle || seo.title} />
        <meta
            property="twitter:description"
            content={seo.ogDescription || seo.description}
        />
        <meta property="twitter:image" content={seo.ogImage} />
        <MetaPixel />
    </head>
    <body>
        <!-- Google Tag Manager (noscript) -->
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NRK6FQ5N"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <!-- End Google Tag Manager (noscript) -->
        <SideCart client:load />
        <SearchDrawer client:load />
        <slot />
        <CookieBanner />
    </body>

    <script>
        function initRevealOnScroll() {
            const observerOptions = {
                threshold: 0.1,
                rootMargin: "0px 0px -50px 0px",
            };

            // Use WeakSet to track processed elements WITHOUT touching their classList
            const processedElements = new WeakSet();

            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("is-visible");
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            function observeNewElements() {
                const elementsToReveal = document.querySelectorAll(
                    ".reveal-on-scroll, img",
                );

                elementsToReveal.forEach((el) => {
                    // Skip already processed elements (no DOM modification needed)
                    if (processedElements.has(el)) return;
                    processedElements.add(el);

                    // Skip images already visible (if any)
                    if (el.classList.contains("is-visible")) return;

                    // If it's an image and not in an astro-island, add class if not present
                    if (el.tagName === "IMG" && !el.closest("astro-island")) {
                        el.classList.add("reveal-on-scroll");
                    }

                    observer.observe(el);
                });
            }

            const mutationObserver = new MutationObserver(() => {
                observeNewElements();
            });

            mutationObserver.observe(document.body, {
                childList: true,
                subtree: true,
            });

            observeNewElements();
        }

        document.addEventListener("astro:page-load", initRevealOnScroll);

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initRevealOnScroll);
        } else {
            initRevealOnScroll();
        }
    </script>
</html>
